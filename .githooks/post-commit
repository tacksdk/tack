#!/usr/bin/env bash
# Remind the developer to bump the submodule pointer in the parent repo.
# The actual staging is handled by tack-app's pre-commit hook automatically.

SHORT_SHA="$(git rev-parse --short HEAD)"
SUBJECT="$(git log -1 --format='%s')"
PARENT_DIR="$(dirname "$(git rev-parse --show-toplevel)")"

# Only print if we're running as a submodule inside another git repo
if [ ! -e "$PARENT_DIR/.git" ]; then
  exit 0
fi

echo ""
echo "  tack → $SHORT_SHA  \"$SUBJECT\""
echo "  Pointer will be auto-staged next time you commit in tack-app."
echo "  Or run:  cd .. && pnpm sync-tack"
echo ""
