{
  "name": "@tacksdk/js",
  "version": "0.0.2",
  "description": "Tack feedback SDK — vanilla JS client",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./headless": {
      "development": "./src/headless.ts",
      "import": "./dist/headless.mjs",
      "require": "./dist/headless.js",
      "types": "./dist/headless.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tacksdk/tack.git",
    "directory": "packages/js"
  },
  "homepage": "https://github.com/tacksdk/tack/tree/main/packages/js#readme",
  "bugs": "https://github.com/tacksdk/tack/issues",
  "keywords": [
    "feedback",
    "widget",
    "tack",
    "in-app"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "jsdom": "29.0.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
